# API base URL — leave empty for same-origin (default in dev via Vite proxy)
# Set to full backend URL for deployed environments, e.g. https://api.ideago.example.com
VITE_API_BASE_URL=

# NOTE: The API key is injected at runtime via APP_API_KEY in the backend .env.
# No VITE_ variable needed — the frontend reads window.__APP_CONFIG__.apiKey at startup.
