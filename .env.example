# Application Settings / 应用配置
# 运行环境，通常为 development（开发环境）、production（生产环境）或 testing（测试环境）
ENVIRONMENT=development

# Logging Settings / 日志配置
# 日志记录级别，控制控制台和文件输出日志的详细程度（例如 DEBUG, INFO, WARNING, ERROR, CRITICAL 等）
LOG_LEVEL=INFO
# 日志文件保存的相对或绝对路径
LOG_FILE=logs/app.log

# ============================================
# API Keys (Required) / API 密钥（必填）
# ============================================
# OpenAI API 密钥，用于访问语言模型服务（必须配置，也可用于兼容的第三方大模型服务）
OPENAI_API_KEY=sk-your-key-here
# Tavily API 密钥，用于进行网络搜索和高质量信息检索
TAVILY_API_KEY=tvly-your-key-here
# Optional Tavily API base URL for custom endpoint
TAVILY_BASE_URL=

# GitHub PAT (Optional, improves rate limit from 10/hr to 5000/hr)
# GitHub 令牌（可选，提高速率限制）
# GitHub 个人访问令牌配置后，可将调取 GitHub 接口获取开源项目信息的频率限制从 10 次/小时 提升至 5000 次/小时
GITHUB_TOKEN=
# Product Hunt Developer Token（可选，启用 Product Hunt 数据源）
PRODUCTHUNT_DEV_TOKEN=
# Reddit OAuth（可选，启用 Reddit 数据源）
# 在 https://www.reddit.com/prefs/apps 创建 "script" 类型应用获取
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ============================================
# LLM Settings / 大模型配置
# ============================================
# 默认使用的大语言模型名称（例如 gpt-4o-mini 或你定制的模型如 deepseek-v3-2-251201）
OPENAI_MODEL=gpt-4o-mini
# 可选：用于 OpenAI 兼容服务商（例如 OpenRouter / 兼容网关）
# 代理或第三方镜像的服务基础 URL（保持为空时不覆盖，默认连通官方服务器）
OPENAI_BASE_URL=
# 每次大模型 API 请求的最大等待超时时间（单位：秒）
OPENAI_TIMEOUT_SECONDS=120
# 备用节点列表（JSON 数组格式）。在高并发或主节点报错（如超时、被限流）时，会自动转移请求备用的模型节点以提高系统可用性
# Example / 例如：
# OPENAI_FALLBACK_ENDPOINTS=[{"name":"openrouter","base_url":"https://openrouter.ai/api/v1","api_key":"sk-xxx","model":"gpt-4o-mini","timeout":60}]
OPENAI_FALLBACK_ENDPOINTS=
# LangGraph 流程图在执行节点逻辑遇到错误时最大允许的重试次数
LANGGRAPH_MAX_RETRIES=2
# 解析大模型返回的 JSON 数据结构失败时，最大允许的纠错或重新解析处理次数
LANGGRAPH_JSON_PARSE_MAX_RETRIES=1

# ============================================
# Pipeline Settings / 管道配置
# ============================================
# 在网络搜索/执行信息抓取阶段，对每个平台检索结果要获取的最大数量
MAX_RESULTS_PER_SOURCE=10
# 获取每一个源数据、爬虫或第三方接口时的请求超时时间（单位：秒）
SOURCE_TIMEOUT_SECONDS=30
# 查询外部信息源接口时的并发线程数/并发数量限制
SOURCE_QUERY_CONCURRENCY=2
# 跨数据源全局并发上限（source 层两级并发中的外层预算）
SOURCE_GLOBAL_CONCURRENCY=3
# Product Hunt 抓取时间窗口（天），仅拉取该时间段内发布的帖子
PRODUCTHUNT_POSTED_AFTER_DAYS=730
# 应用商店相关查询请求的默认国家或地区代码（如 us 代表美区、cn 代表国区）
APPSTORE_COUNTRY=cn
# 执行文本长文信息提取任务时的超时时间配置（单位：秒）
EXTRACTION_TIMEOUT_SECONDS=180
# Sqlite 或本地数据库的路径，用来存储 LangGraph 的中间状态流转（实现断点续传或进度回溯记录）
LANGGRAPH_CHECKPOINT_DB_PATH=.cache/ideago/langgraph-checkpoints.db

# ============================================
# Supabase Auth / 认证配置
# ============================================
# Supabase 项目 URL（在 Supabase Dashboard > Settings > API 中获取）
SUPABASE_URL=https://your-project.supabase.co
# Supabase 匿名密钥（前端可公开使用的 anon / publishable key）
SUPABASE_ANON_KEY=your-anon-key
# Supabase JWT Secret（Dashboard → Settings → API → JWT Secret）
# 配置后启用本地 JWT 验证（<1ms），不配置则回退到 HTTP 远程验证（~100-200ms）
SUPABASE_JWT_SECRET=your-jwt-secret
# Supabase service_role key（Dashboard → Settings → API → service_role secret）
# Backend-only key for bypassing RLS. NEVER expose to frontend!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AUTH_SESSION_SECRET=change-me-to-a-random-long-secret
AUTH_SESSION_EXPIRE_HOURS=720
FRONTEND_APP_URL=https://ideago.simonsun.cc
LINUXDO_CLIENT_ID=your-linuxdo-client-id
LINUXDO_CLIENT_SECRET=your-linuxdo-client-secret
LINUXDO_AUTHORIZE_URL=https://connect.linux.do/oauth2/authorize
LINUXDO_TOKEN_URL=https://connect.linux.do/oauth2/token
LINUXDO_USERINFO_URL=https://connect.linux.do/api/user
LINUXDO_SCOPE=openid profile email

# ============================================
# Cache Settings / 缓存配置
# ============================================
# 项目系统存放缓存数据、本地临时处理文件的根目录
CACHE_DIR=.cache/ideago
# 缓存数据的有效存活时长（TTL），超过此时长（单位：小时）数据将可能被标记丢弃或重新抓取
CACHE_TTL_HOURS=24

# ============================================
# Server Settings / 服务配置
# ============================================
# 后端服务绑定的主机地址。0.0.0.0 表示允许来自所有局域网/公网 IP 地址的入站访问
HOST=0.0.0.0
# 后端服务启动并监听的端口号
PORT=8000
# 跨域资源共享（CORS）策略允许的源站点（前端）域名列表。 '*' 代表允许所有网站跨域调用接口
CORS_ALLOW_ORIGINS=*
# 注意：部署到生产环境时，CORS_ALLOW_ORIGINS 应设置为明确的前端域名
# 例如：CORS_ALLOW_ORIGINS=https://ideago.example.com
