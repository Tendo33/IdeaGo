# Application Settings / 应用配置
ENVIRONMENT=development

# Logging Settings / 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================
# API Keys (Required) / API 密钥（必填）
# ============================================
OPENAI_API_KEY=sk-your-key-here
TAVILY_API_KEY=tvly-your-key-here

# GitHub PAT (Optional, improves rate limit from 10/hr to 5000/hr)
# GitHub 令牌（可选，提高速率限制）
GITHUB_TOKEN=

# ============================================
# LLM Settings / 大模型配置
# ============================================
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60

# ============================================
# Pipeline Settings / 管道配置
# ============================================
MAX_RESULTS_PER_SOURCE=10
SOURCE_TIMEOUT_SECONDS=30
EXTRACTION_TIMEOUT_SECONDS=60

# ============================================
# Cache Settings / 缓存配置
# ============================================
CACHE_DIR=.cache/ideago
CACHE_TTL_HOURS=24

# ============================================
# Server Settings / 服务配置
# ============================================
HOST=0.0.0.0
PORT=8000
CORS_ALLOW_ORIGINS=*
